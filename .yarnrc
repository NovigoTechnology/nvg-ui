# Yarn v1 configuration
# See: https://classic.yarnpkg.com/en/docs/yarnrc/

# GitHub Packages registry for @novigotechnology scope
"@novigotechnology:registry" "https://npm.pkg.github.com"

# Save exact versions (no ^ or ~)
save-prefix ""

# Disable workspaces (not a monorepo)
workspaces-experimental false

# Ignore engines check warnings (we have engine-strict in .npmrc)
ignore-engines false
