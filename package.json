{
  "name": "@novigotechnology/nvg-ui",
  "version": "1.23.0",
  "description": "NVG components",
  "private": false,
  "main": "dist/nvg-ui.umd.js",
  "module": "dist/nvg-ui.es.js",
  "types": "src/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src/index.d.ts",
    "scripts"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "homepage": "https://github.com/NovigoTechnology/nvg-ui#readme",
  "bugs": {
    "url": "https://github.com/NovigoTechnology/nvg-ui/issues"
  },
  "repository": {
    "url": "git+https://github.com/NovigoTechnology/nvg-ui.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=24",
    "yarn": ">=1.22.0"
  },
  "peerDependencies": {
    "@primeuix/themes": "^2.0.0",
    "primevue": "^4.5.5",
    "vue": ">=3.5.32"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@primeuix/themes": "^2.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.0",
    "jsdom": "29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "primevue": "^4.5.5",
    "semantic-release": "^25.0.7",
    "typescript": "7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vitest": "4.1.10",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1"
  },
  "dependencies": {
    "dompurify": "3.4.12",
    "libphonenumber-js": "^1.13.8",
    "lodash-es": "^4.18.0",
    "mitt": "^3.0.1"
  },
  "scripts": {
    "preinstall": "sh scripts/preinstall.sh",
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "lint": "eslint src demo",
    "lint:fix": "eslint src demo --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{js,vue}\" \"demo/**/*.{js,vue}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue}\" \"demo/**/*.{js,vue}\"",
    "prepare": "husky && yarn build",
    "version:patch": "yarn version --patch --message 'chore(release): v%s'",
    "version:minor": "yarn version --minor --message 'chore(release): v%s'",
    "version:major": "yarn version --major --message 'chore(release): v%s'",
    "release": "yarn build && yarn semantic-release"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "resolutions": {
    "@actions/http-client/**/undici": "6.27.0",
    "postcss": "^8.5.10"
  }
}
