{
  "name": "@novigotechnology/nvg-ui",
  "version": "1.4.0",
  "description": "NVG components",
  "private": false,
  "main": "dist/nvg-ui.umd.js",
  "module": "dist/nvg-ui.es.js",
  "types": "src/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "homepage": "https://github.com/NovigoTechnology/nvg-ui#readme",
  "bugs": {
    "url": "https://github.com/NovigoTechnology/nvg-ui/issues"
  },
  "repository": {
    "url": "git+https://github.com/NovigoTechnology/nvg-ui.git"
  },
  "license": "CSCL",
  "peerDependencies": {
    "@primeuix/themes": "^2.0.0",
    "primevue": "^4.0.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@primeuix/themes": "^2.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.0.11",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "primeflex": "^4.0.0",
    "primevue": "^4.5.4",
    "semantic-release": "^25.0.3",
    "vite": "^6.4.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vue": "^3.5.32"
  },
  "dependencies": {
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1"
  },
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "lint": "eslint src demo",
    "lint:fix": "eslint src demo --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\" \"demo/**/*.{js,vue}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue}\" \"demo/**/*.{js,vue}\"",
    "prepare": "husky && npm run build",
    "commit": "git-cz",
    "version:patch": "npm version patch -m 'chore(release): v%s'",
    "version:minor": "npm version minor -m 'chore(release): v%s'",
    "version:major": "npm version major -m 'chore(release): v%s'",
    "release": "npm run build && npx semantic-release"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
